{
  "version": 2,
  "buildCommand": "python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "admin_libros/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "admin_libros/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "admin_libros.settings"
  }
}
